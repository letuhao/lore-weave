# PRR-12: normalize all text files to LF so Windows Git (core.autocrlf=true)
# stops the "LF will be replaced by CRLF" churn on every `git add`. Binary
# build artifacts are marked explicitly so Git never tries to munge them.
* text=auto eol=lf
*.png binary
*.jpg binary
*.exe binary
*.parquet binary

# Force LF for files that run inside Linux containers
*.sh text eol=lf
Dockerfile text eol=lf
*.sql text eol=lf
*.conf text eol=lf

# /review-impl 2026-05-24 LOW #6: pnpm always writes LF; Windows Git with
# core.autocrlf=true (Windows installer default) would convert to CRLF on
# checkout, then pnpm rewrites back to LF on next install — producing a
# noisy "lockfile changed" diff on every commit. Pin LF for pnpm-lock +
# all YAML to avoid the round-trip churn.
pnpm-lock.yaml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
