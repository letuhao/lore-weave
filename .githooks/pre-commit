#!/usr/bin/env sh
# LoreWeave pre-commit — enforce key invariants (CLAUDE.md › Key Rules):
#   • Provider gateway invariant: no direct provider-SDK usage outside the gateway
#   • No hardcoded model names in runtime code
#   • INV-KAL (table-read half): no direct glossary-EAV / Neo4j read outside the owning
#     services — read entity/KG knowledge through the knowledge-gateway (KAL).
#   • INV-KAL (HTTP-surface half): no consumer hits the owning services' bi-temporal
#     knowledge /internal endpoints (facts/canonical/timeline/attr-values/search/
#     neighborhood/retrieve) — read them through the KAL. (Both halves now ENFORCED.)
# Checks only STAGED files (fast). Bypass in a true emergency with `git commit --no-verify`.
#
# Activate (per checkout):  git config core.hooksPath .githooks
set -e
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
PY=python
command -v python >/dev/null 2>&1 || PY=python3
"$PY" "$ROOT/scripts/ai-provider-gate.py" --staged
"$PY" "$ROOT/scripts/knowledge-access-gate.py" --staged
"$PY" "$ROOT/scripts/knowledge-http-surface-gate.py" --staged

# Track A / M9a — the central C-TOOL tier gate: a write-verb-named tool must NOT be Tier-R
# (Tier-R auto-runs with no confirm/Undo — a mutation tagged R is a silent-write). Runs when a
# tool-registration file (or the gate itself) is staged; it scans the whole tree, so this
# condition only skips it on commits that can't affect a tool's tier.
if git diff --cached --name-only | grep -qE 'NewToolMeta|mcp_server\.go|_tools\.go|tool_discovery|tier-tag-gate'; then
  "$PY" "$ROOT/scripts/tier-tag-gate.py"
fi

# Context Budget Law §13c — keep the §11a Inspector coverage manifest un-gameable:
# whenever the spec or any Inspector test/component is staged, every §11a checklist
# item must still bind to an existing proving test (static, no suite execution).
if git diff --cached --name-only | grep -qE '2026-07-03-context-budget-law\.md|features/chat/inspector/|context-inspector'; then
  "$PY" "$ROOT/scripts/context-inspector-checklist-gate.py"
fi

# Spec 30 §8.3 / X-8 — destructive+warning token drift in the studio design drafts.
# The original audit grepped token NAMES and so missed a 5th drift wearing a THIRD name
# (`--error: #e85a5a`), a raw hex with no token at all, and an `rgba(217,93,93)` that is
# #d95d5d spelled in decimal. This lint greps by the COLOR (HSL), not by the name.
# Runs only when a studio draft is staged (same conditional shape as the gate above).
if git diff --cached --name-only | grep -qE 'design-drafts/screens/studio/.*\.html'; then
  "$PY" "$ROOT/scripts/design-draft-token-lint.py"
fi

# SEC-1 / audit P0-6: catch secrets BEFORE they enter a commit. gitleaks scans
# only the staged diff (`protect --staged`) so this stays fast. gitleaks is an
# optional local tool — if it isn't installed we warn and continue (CI's
# all-branch `secrets` job in foundation-ci.yml is the backstop); if it IS
# installed, a finding fails the commit (set -e). Bypass in a true emergency
# with `git commit --no-verify`.
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --redact --config "$ROOT/.gitleaks.toml"
else
  echo "pre-commit: gitleaks not installed — skipping staged secret scan (install: https://github.com/gitleaks/gitleaks; CI still scans on push)." >&2
fi
