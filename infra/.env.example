# Optional overrides for docker compose (copy to .env next to docker-compose.yml)
# JWT_SECRET must be at least 32 characters if set.
# JWT_SECRET=

# ── WS-1.0 · diary/assistant encryption KEK (REQUIRED for any non-local deployment) ──
# Wraps each user's per-user data key; that key encrypts diary bodies, assistant chat and
# private KG facts. Without it the stack falls back to the PUBLIC dev default baked into
# docker-compose.yml, which is equivalent to storing that content unencrypted.
#   Generate:  openssl rand -base64 48
# DIARY_ENCRYPTION_KEY=
#
# ⚠️ ROTATION IS A DATA-LOSS OPERATION IF YOU SKIP THIS. Every service unwraps a user's
# key by trying the active KEK, then each retired one. If you ever CHANGE
# DIARY_ENCRYPTION_KEY you MUST move the OLD value here (comma-separated) — otherwise every
# existing user's diary, assistant chat and facts become permanently unreadable. Set it on
# EVERY service (auth, chat, knowledge, worker-ai) at the same time.
# DIARY_ENCRYPTION_KEYS_RETIRED=

# API base URL baked into the frontend static build at `docker compose build` time
# (Vite compile-time var — changing it later requires a rebuild, not just a restart).
# Leave unset/empty (the default): the browser calls relative /v1, which this
# container's own nginx.conf proxies to api-gateway-bff — works unchanged behind
# any origin (localhost, LAN IP, ngrok, a real domain). Only set this to an
# absolute URL for a non-proxied custom setup (frontend and gateway on different,
# unrelated origins).
# VITE_API_BASE=

# Used in verification/reset emails and as the OAuth audience base for public MCP
# (mcp-public-gateway's MCP_RESOURCE_URL derives from this — see below). Must be
# the exact origin you open the UI at in the browser (e.g. your ngrok URL).
# PUBLIC_APP_URL=http://localhost:5174

# Public MCP (external-agent entry, /mcp) OAuth resource identifier. MUST equal
# <PUBLIC_APP_URL>/mcp exactly (both sides sign/verify against this audience) —
# set it together with PUBLIC_APP_URL, same origin, just with /mcp appended.
# frontend/nginx.conf proxies /mcp -> api-gateway-bff -> mcp-public-gateway, so
# no separate port/domain is needed for MCP either.
# MCP_RESOURCE_URL=http://localhost:5174/mcp

# Module 02 services default ports
# BOOK_SERVICE_URL=http://localhost:8205
# SHARING_SERVICE_URL=http://localhost:8206
# CATALOG_SERVICE_URL=http://localhost:8207

# Public URL browsers use to fetch MinIO objects (book covers, TTS/video output,
# chat attachments). frontend/nginx.conf proxies /media/ -> minio:9000, so for a
# single-port deployment (e.g. ngrok) set this to your public origin + /media,
# e.g. https://your-tunnel.ngrok-free.app/media. Must match VITE_API_BASE's origin.
# MINIO_EXTERNAL_URL=http://localhost:9123
