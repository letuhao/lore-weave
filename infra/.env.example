# Optional overrides for docker compose (copy to .env next to docker-compose.yml)
# JWT_SECRET must be at least 32 characters if set.
# JWT_SECRET=

# API base URL baked into the frontend static build (must be reachable from the browser).
# Use http://localhost:3000 when you open the UI at http://localhost:5173
# VITE_API_BASE=http://localhost:3000

# Used in verification/reset emails (must match where you open the UI in the browser).
# PUBLIC_APP_URL=http://localhost:5173
