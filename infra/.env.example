# Optional overrides for docker compose (copy to .env next to docker-compose.yml)
# JWT_SECRET must be at least 32 characters if set.
# JWT_SECRET=

# API base URL baked into the frontend static build (must be reachable from the browser).
# Use http://localhost:3123 when you open the UI at http://localhost:5296
# VITE_API_BASE=http://localhost:3123

# Used in verification/reset emails (must match where you open the UI in the browser).
# PUBLIC_APP_URL=http://localhost:5296

# Module 02 services default ports
# BOOK_SERVICE_URL=http://localhost:8205
# SHARING_SERVICE_URL=http://localhost:8206
# CATALOG_SERVICE_URL=http://localhost:8207
