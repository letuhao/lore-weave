# Copy to infra/.env and customize.
#
# ── Dev (default compose only) ──
# Optional JWT override (>= 32 chars):
# JWT_SECRET=

# ── Prod overlay (docker-compose.prod.yml) ──
# REQUIRED for prod — compose fails to start without it:
JWT_SECRET=change-me-min-32-characters-long
INTERNAL_SERVICE_TOKEN=change-me-different-from-jwt-min-32-chars

# Public URL the browser uses (ngrok HTTPS URL or your domain).
# After first `ngrok http $PUBLIC_HTTP_PORT`, paste the URL here and re-up.
PUBLIC_APP_URL=https://your-subdomain.ngrok-free.app

# Single host port exposed to the internet (default 5296 — avoids :80 conflicts).
PUBLIC_HTTP_PORT=5296

# Browser-reachable MinIO prefix for media URLs. Defaults to PUBLIC_APP_URL in prod overlay.
# MINIO_EXTERNAL_URL=https://your-subdomain.ngrok-free.app

# Prod overlay: restrict BFF CORS (defaults to PUBLIC_APP_URL).
# BFF_CORS_ORIGINS=https://your-subdomain.ngrok-free.app

# Prod: disable public self-registration (invite/admin only).
# ALLOW_PUBLIC_REGISTRATION=false

# BFF rate limit (prod overlay defaults: 120 req / 60s per IP on /v1/*).
# BFF_RATE_LIMIT_MAX_REQUESTS=120
# BFF_RATE_LIMIT_WINDOW_SECONDS=60

# Pre-seeded users for security probes when registration is disabled:
# SEC_REVIEW_EMAIL_A=sec-review-a@yourdomain.local
# SEC_REVIEW_PASSWORD_A=...
# SEC_REVIEW_EMAIL_B=sec-review-b@yourdomain.local
# SEC_REVIEW_PASSWORD_B=...
# REALTEST_EMAIL=realtest@yourdomain.local
# REALTEST_PASSWORD=...

# Prod email (required unless using --profile dev-mail for internal Mailhog only):
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_FROM=LoreWeave <noreply@example.com>

# ── Dev-only: baked into frontend image when not using prod overlay ──
# Leave unset in prod (VITE_API_BASE="" = same-origin /v1 via nginx).
# VITE_API_BASE=http://localhost:3123
