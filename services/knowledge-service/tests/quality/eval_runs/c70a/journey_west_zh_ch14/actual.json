  "events": [
    {
      "summary": "三藏在山頂的四方大石前，跪拜禱祝後，將刻有「唵嘛呢叭𠺗吽」六個金字的壓帖輕輕揭下。",
      "participants": [
        "陳玄奘"
      ]
    },
    {
      "summary": "三藏揭起金字壓帖後，孫悟空自石中現身而出。",
      "participants": [
        "孫悟空"
      ]
    },
    {
      "summary": "孫悟空向三藏敘述自己五百年前大鬧天宮的經歷，並表達願意保護取經人、歸依佛法、與師父一同前往西方拜佛。",
      "participants": [
        "孫悟空",
        "陳玄奘"
      ]
    },
    {
      "summary": "三藏問孫悟空姓氏，得知其名為孫，並起法名孫悟空。",
      "participants": [
        "陳玄奘",
        "孫悟空"
      ]
    },
    {
      "summary": "三藏見孫悟空形貌如小頭陀，遂為其起混名「行者」。",
      "participants": [
        "陳玄奘",
        "孫悟空"
      ]
    },
    {
      "summary": "伯欽扶著三藏，攀藤附葛，一同登上高山。",
      "participants": [
        "伯欽",
        "陳玄奘"
      ]
    },
    {
      "summary": "三藏問孫悟空如何能從山中救出他，孫悟空答以金字壓帖之法。",
      "participants": [
        "陳玄奘",
        "孫悟空"
      ]
    },
    {
      "summary": "觀音菩薩勸導孫悟空不再行兇，歸依佛法，並教他殷勤保護取經人。",
      "participants": [
        "觀音菩薩",
        "孫悟空"
      ]
    },
    {
      "summary": "自此時起，孫悟空被稱為孫行者。",
      "participants": [
        "孫悟空"
      ]
    },
    {
      "summary": "觀音菩薩奉佛旨意，前往東土尋找取經人。",
      "participants": [
        "觀音菩薩"
      ]
    },
    {
      "summary": "伯欽呼叫家僮，並牽來馬匹。",
      "participants": [
        "伯欽",
        "家僮"
      ]
    }
  ]
