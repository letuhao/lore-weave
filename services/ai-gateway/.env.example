# ai-gateway ‚Äî internal AI/MCP federation gateway
AI_GATEWAY_PORT=8210
# REQUIRED ‚Äî the service refuses to start if empty (no hardcoded secrets).
INTERNAL_SERVICE_TOKEN=change-me
# Provider registry (C-GW) ‚Äî comma-separated `name=url`. Adding a provider is an
# env edit, not a code change. Prefix is resolved by name from the built-in map
# (knowledge‚Üímemory_, glossary‚Üíglossary_, book‚Üíbook_, composition‚Üícomposition_,
# translation‚Üítranslation_, settings‚Üísettings_, jobs‚Üíjobs_); override inline with
# `name|prefix_=url`. Unset/empty ‚áí falls back to the knowledge+glossary defaults.
# AI_GATEWAY_PROVIDERS=knowledge=http://knowledge-service:8092/mcp,glossary=http://glossary-service:8088/mcp
# Legacy per-provider URLs (used only by the fallback defaults when AI_GATEWAY_PROVIDERS is unset).
KNOWLEDGE_MCP_URL=http://knowledge-service:8092/mcp
GLOSSARY_MCP_URL=http://glossary-service:8088/mcp
# Federated-catalog refresh interval (ms) ‚Äî H10.
AI_GATEWAY_CATALOG_REFRESH_MS=30000
