# ai-gateway — internal AI/MCP federation gateway
AI_GATEWAY_PORT=8210
# REQUIRED — the service refuses to start if empty (no hardcoded secrets).
INTERNAL_SERVICE_TOKEN=change-me
# Provider MCP endpoints (P0: knowledge only; glossary added at P1).
KNOWLEDGE_MCP_URL=http://knowledge-service:8092/mcp
# Federated-catalog refresh interval (ms) — H10.
AI_GATEWAY_CATALOG_REFRESH_MS=30000
