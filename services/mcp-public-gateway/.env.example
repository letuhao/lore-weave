# mcp-public-gateway — env (no hardcoded secrets; service fails fast without the internal token)

# Listen port (host-mapped; reached via api-gateway-bff /mcp in prod)
MCP_PUBLIC_GATEWAY_PORT=8211

# Service-to-service token the edge mints toward ai-gateway (NEVER exposed to external agents)
INTERNAL_SERVICE_TOKEN=

# The internal MCP federation gateway this edge relays to (always the user /mcp surface, never /mcp/admin)
AI_GATEWAY_URL=http://ai-gateway:8210

# Q-GATE feature flag — public MCP is OFF unless explicitly enabled (fast kill-switch)
PUBLIC_MCP_ENABLED=false

# ── P0 ONLY (removed at P1 when the real mcp_api_keys credential store lands) ──
# A single static test credential so the envelope hop can be live-smoked before
# the credential subsystem exists. Bearer <MCP_PUBLIC_TEST_KEY> resolves to MCP_PUBLIC_TEST_USER_ID.
MCP_PUBLIC_TEST_KEY=
MCP_PUBLIC_TEST_USER_ID=
