PORT=3123
AUTH_SERVICE_URL=http://localhost:8204
BOOK_SERVICE_URL=http://localhost:8205
SHARING_SERVICE_URL=http://localhost:8206
CATALOG_SERVICE_URL=http://localhost:8207

# D-EDGE-RATELIMIT — HTTP-edge fixed-window rate limiter (fail-open).
# REDIS_URL enables it; with no REDIS_URL the limiter is a pass-through.
REDIS_URL=redis://localhost:6379
EDGE_RATE_LIMIT_MAX=300              # max requests per USER (sub) per window
EDGE_RATE_LIMIT_IP_MAX=1500          # max requests per IP per window (backstop a forged/rotating sub; higher for shared NAT)
EDGE_RATE_LIMIT_WINDOW_S=60          # window length in seconds
EDGE_RATE_LIMIT_ENABLED=true         # set to "false" to disable
EDGE_RATE_LIMIT_REDIS_TIMEOUT_MS=100 # per-command timeout so a WEDGED Redis rejects → fail-open (not a hung request)
EDGE_TRUSTED_PROXIES=1               # trusted reverse-proxy hop count (ALB=1) so req.ip isn't a client-spoofable XFF hop
# INTERNAL_SERVICE_TOKEN is reused: a request whose x-internal-token VALUE equals it is exempt (a spoofed one is stripped).
