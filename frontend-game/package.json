{
  "name": "frontend-game",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "LoreWeave MMORPG client. Hybrid React UI overlay + Phaser 4 canvas. Per spec docs/specs/2026-05-24-frontend-game-architecture.md.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 5174",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@loreweave/api-types": "workspace:^",
    "@loreweave/auth-client": "workspace:^",
    "@loreweave/design-tokens": "workspace:^",
    "@loreweave/i18n": "workspace:^",
    "@tanstack/react-query": "^5",
    "phaser": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6",
    "zustand": "^5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^1"
  }
}
