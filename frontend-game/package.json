{
  "name": "frontend-game",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "LoreWeave MMORPG client. Hybrid React UI overlay + Phaser 4 canvas. Per spec docs/specs/2026-05-24-frontend-game-architecture.md.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 5174",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test --project=chromium",
    "e2e:all-browsers": "playwright test",
    "e2e:install": "playwright install --with-deps",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "check:bundle-size": "node scripts/check-bundle-size.mjs"
  },
  "dependencies": {
    "@loreweave/api-types": "workspace:^",
    "@loreweave/auth-client": "workspace:^",
    "@loreweave/design-tokens": "workspace:^",
    "@loreweave/i18n": "workspace:^",
    "@react-three/drei": "^10.7",
    "@react-three/fiber": "^8.17",
    "@tanstack/react-query": "^5",
    "colyseus.js": "^0.16",
    "phaser": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7",
    "three": "^0.169",
    "zustand": "^5"
  },
  "devDependencies": {
    "@playwright/test": "^1.49",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.169",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-plugin-react": "^7",
    "eslint-plugin-react-hooks": "^5",
    "globals": "^17",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.8",
    "prettier": "^3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8",
    "vite": "^8.1.3",
    "vitest": "^1"
  }
}
