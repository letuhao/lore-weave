{
  "title": "Capacity planner (cycle 6 L1.L — backfilled cycle 34)",
  "uid": "capacity-planner",
  "tags": ["capacity", "cycle-6", "cycle-34-backfill", "L1.L", "SR08"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "editable": true,
  "graphTooltip": 0,
  "annotations": {"list": []},
  "templating": {"list": []},
  "time": {"from": "now-24h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Per-shard utilization %",
      "description": "Per-shard utilization vs warning + full thresholds.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prom-primary"},
      "targets": [
        {"expr": "lw_shard_utilization_pct{}", "legendFormat": "{{shard_host}}", "refId": "A"},
        {"expr": "vector(80)", "legendFormat": "warning_pct", "refId": "B"},
        {"expr": "vector(95)", "legendFormat": "full_pct", "refId": "C"}
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active capacity overrides (24h cap)",
      "description": "Active capacity overrides (Tier-2 S5-D5).",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prom-primary"},
      "targets": [
        {"expr": "lw_capacity_override_active_count{}", "legendFormat": "active overrides", "refId": "A"}
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Replica count by service+class",
      "description": "Per-class replica count vs budget min/max.",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prom-primary"},
      "targets": [
        {"expr": "sum by (service, class) (lw_replica_count{})", "legendFormat": "{{service}} ({{class}})", "refId": "A"}
      ]
    }
  ]
}
