      "description": "Per-shard utilization vs warning + full thresholds.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "targets": [
        {"expr": "lw_shard_utilization_pct{}", "legendFormat": "{{shard_host}}"},
        {"expr": "vector(80)", "legendFormat": "warning_pct"},
        {"expr": "vector(95)", "legendFormat": "full_pct"}
      ],
      "title": "Per-shard utilization %",
      "type": "graph"
    },
    {
      "datasource": "Prometheus",
      "description": "Active capacity overrides (Tier-2 S5-D5).",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [
        {"expr": "lw_capacity_override_active_count{}", "legendFormat": "active overrides"}
      ],
      "title": "Active capacity overrides (24h cap)",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
