{
  "annotations": {"list": []},
  "description": "Per-shard overview — L1.I.8 (RAID cycle 6). Aggregates across all realities on a shard. Uses recording rules from infra/prometheus/recording-rules.yaml. Q-L1I-1: HA pair via federation; this dashboard reads from federated prom.",
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "targets": [
        {
          "expr": "lw:reality_db_size_bytes:sum_by_shard{shard_host=\"$shard\"}",
          "legendFormat": "total bytes on {{ shard_host }}",
          "refId": "A"
        }
      ],
      "title": "Total per-reality DB bytes (aggregated)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [
        {
          "expr": "lw:reality_db_connections:sum_by_shard{shard_host=\"$shard\"}",
          "legendFormat": "{{ shard_host }} connections",
          "refId": "A"
        }
      ],
      "title": "Backend connections on shard",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "targets": [
        {
          "expr": "shard_utilization_realities_used{shard_host=\"$shard\"} / shard_utilization_realities_total{shard_host=\"$shard\"}",
          "legendFormat": "utilization fraction",
          "refId": "A"
        }
      ],
      "title": "Capacity utilization (warning at 0.7, full at 0.9 per capacity-thresholds.yaml)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "targets": [
        {
          "expr": "lw:meta_replication_lag_bytes:max",
          "legendFormat": "max meta replica lag",
          "refId": "A"
        }
      ],
      "title": "Meta-postgres replication lag (across all replicas)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 16},
      "id": 5,
      "targets": [
        {
          "expr": "pgbouncer_pool_waiting_clients{shard_host=\"$shard\"}",
          "legendFormat": "{{ pool_name }} waiting",
          "refId": "A"
        }
      ],
      "title": "Pgbouncer waiting clients (zero = healthy)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 27,
  "style": "dark",
  "tags": ["lw", "shard", "l1"],
  "templating": {
    "list": [
      {
        "current": {"selected": false, "text": "All", "value": "$__all"},
        "datasource": "Prometheus",
        "definition": "label_values(shard_utilization_realities_used, shard_host)",
        "hide": 0,
        "includeAll": false,
        "label": "Shard",
        "multi": false,
        "name": "shard",
        "options": [],
        "query": "label_values(shard_utilization_realities_used, shard_host)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timezone": "",
  "title": "LoreWeave — Shard Health",
  "uid": "lw-shard-health",
  "version": 1
}
